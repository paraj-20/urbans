{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "section": {
      "type": "enumeration",
      "enum": [
        "trending",
        "clothing",
        "accessories"
      ]
    },
    "subcategory": {
      "type": "enumeration",
      "enum": [
        "shirt",
        "tshirt",
        "jackets",
        "pants",
        "jeans",
        "aesthetics",
        "caps",
        "backpack"
      ]
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "product"
    },
    "isNew": {
      "type": "boolean"
    }
  }
}
